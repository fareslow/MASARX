{
  "name": "masarx-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @masarx/web",
    "dev:admin": "npm run dev --workspace @masarx/admin",
    "dev:api": "npm run start:dev --workspace @masarx/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
