generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  TRIAL
  SUSPENDED
}

enum OrderStatus {
  NEW
  REVIEW
  READY_TO_SHIP
  SHIPMENT_CREATED
  AWAITING_PICKUP
  IN_TRANSIT
  DELIVERED
  DELIVERY_FAILED
  RETURNED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  COD
  REFUNDED
}

enum ShipmentStatus {
  CREATED
  READY_FOR_PICKUP
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURNED
  CANCELLED
}

enum IntegrationType {
  COMMERCE
  CARRIER
  MESSAGING
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  NEEDS_UPDATE
}

model Account {
  id             String                  @id @default(cuid())
  name           String
  slug           String                  @unique
  status         AccountStatus           @default(TRIAL)
  defaultLocale  String                  @default("ar")
  defaultCurrency String                 @default("SAR")
  countryCode    String                  @default("SA")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  users          AccountUser[]
  stores         Store[]
  branches       Branch[]
  customers      Customer[]
  orders         Order[]
  shipments      Shipment[]
  integrations   IntegrationConnection[]
  pricingTables  PricingTable[]
  quoteRequests  QuoteRequest[]
  auditLogs      AuditLog[]
  settings       Setting[]
  returnRequests ReturnRequest[]
}

model User {
  id              String        @id @default(cuid())
  fullName        String
  email           String?       @unique
  phone           String?       @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        AccountUser[]
}

model AccountUser {
  id              String            @id @default(cuid())
  accountId       String
  userId          String
  status          String            @default("active")
  isOwner         Boolean           @default(false)
  defaultBranchId String?
  createdAt       DateTime          @default(now())
  account         Account           @relation(fields: [accountId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  roles           AccountUserRole[]

  @@unique([accountId, userId])
}

model Role {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  accountUsers AccountUserRole[]
}

model AccountUserRole {
  id            String      @id @default(cuid())
  accountUserId String
  roleId        String
  accountUser   AccountUser @relation(fields: [accountUserId], references: [id])
  role          Role        @relation(fields: [roleId], references: [id])

  @@unique([accountUserId, roleId])
}

model Store {
  id              String    @id @default(cuid())
  accountId       String
  name            String
  platform        String
  externalStoreId String?
  status          String    @default("active")
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  account         Account   @relation(fields: [accountId], references: [id])
  orders          Order[]
}

model Branch {
  id          String      @id @default(cuid())
  accountId   String
  name        String
  code        String?
  city        String
  addressLine String
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  account     Account     @relation(fields: [accountId], references: [id])
  warehouses  Warehouse[]
  orders      Order[]
}

model Warehouse {
  id          String      @id @default(cuid())
  branchId    String
  name        String
  city        String
  addressLine String
  isDefault   Boolean     @default(false)
  branch      Branch      @relation(fields: [branchId], references: [id])
  shipments   Shipment[]
}

model Customer {
  id             String      @id @default(cuid())
  accountId      String
  fullName       String
  email          String?
  phone          String?
  notes          String?
  totalOrders    Int         @default(0)
  totalReturns   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  account        Account     @relation(fields: [accountId], references: [id])
  addresses      Address[]
  orders         Order[]
}

model Address {
  id          String    @id @default(cuid())
  customerId  String
  label       String?
  line1       String
  line2       String?
  city        String
  state       String?
  postalCode  String?
  countryCode String    @default("SA")
  isDefault   Boolean   @default(false)
  customer    Customer  @relation(fields: [customerId], references: [id])
}

model Order {
  id                String         @id @default(cuid())
  accountId         String
  storeId           String?
  customerId        String
  branchId          String?
  orderNumber       String
  externalOrderId   String?
  status            OrderStatus    @default(NEW)
  paymentStatus     PaymentStatus  @default(UNPAID)
  fulfillmentStatus String?
  currency          String         @default("SAR")
  subtotalAmount    Decimal        @db.Decimal(10, 2)
  shippingAmount    Decimal        @db.Decimal(10, 2)
  codAmount         Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal        @db.Decimal(10, 2)
  notes             String?
  placedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  account           Account        @relation(fields: [accountId], references: [id])
  store             Store?         @relation(fields: [storeId], references: [id])
  customer          Customer       @relation(fields: [customerId], references: [id])
  branch            Branch?        @relation(fields: [branchId], references: [id])
  items             OrderItem[]
  shipments         Shipment[]
  returnRequests    ReturnRequest[]

  @@unique([accountId, orderNumber])
  @@index([accountId, status, placedAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  sku        String?
  name       String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  order      Order    @relation(fields: [orderId], references: [id])
}

model Shipment {
  id                  String                @id @default(cuid())
  accountId           String
  orderId             String?
  warehouseId         String?
  carrierConnectionId String?
  carrierServiceCode  String?
  trackingNumber      String?               @unique
  referenceNumber     String?
  status              ShipmentStatus        @default(CREATED)
  etaDate             DateTime?
  shippingCost        Decimal               @default(0) @db.Decimal(10, 2)
  codFee              Decimal               @default(0) @db.Decimal(10, 2)
  labelUrl            String?
  manifestUrl         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  account             Account               @relation(fields: [accountId], references: [id])
  order               Order?                @relation(fields: [orderId], references: [id])
  warehouse           Warehouse?            @relation(fields: [warehouseId], references: [id])
  carrierConnection   IntegrationConnection? @relation(fields: [carrierConnectionId], references: [id])
  events              ShipmentEvent[]
  returnRequests      ReturnRequest[]

  @@index([accountId, status, createdAt])
}

model ShipmentEvent {
  id               String   @id @default(cuid())
  shipmentId       String
  provider         String
  providerEventId  String?
  rawStatus        String
  normalizedStatus String
  description      String?
  eventTime        DateTime
  rawPayload       Json
  shipment         Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId, eventTime])
}

model ReturnRequest {
  id          String    @id @default(cuid())
  accountId   String
  orderId     String?
  shipmentId  String?
  status      String    @default("pending")
  reason      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  account     Account   @relation(fields: [accountId], references: [id])
  order       Order?    @relation(fields: [orderId], references: [id])
  shipment    Shipment? @relation(fields: [shipmentId], references: [id])
}

model IntegrationConnection {
  id                   String               @id @default(cuid())
  accountId            String
  type                 IntegrationType
  provider             String
  displayName          String
  status               ConnectionStatus     @default(DISCONNECTED)
  encryptedCredentials String
  settingsJson         Json?
  lastSyncAt           DateTime?
  lastErrorAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  account              Account              @relation(fields: [accountId], references: [id])
  shipments            Shipment[]
  syncRuns             IntegrationSyncRun[]
  logs                 IntegrationLog[]

  @@index([accountId, type, provider])
}

model IntegrationSyncRun {
  id           String                @id @default(cuid())
  connectionId String
  status       String
  summary      String?
  startedAt    DateTime              @default(now())
  finishedAt   DateTime?
  connection   IntegrationConnection @relation(fields: [connectionId], references: [id])
}

model IntegrationLog {
  id           String                @id @default(cuid())
  connectionId String
  level        String
  message      String
  payload      Json?
  createdAt    DateTime              @default(now())
  connection   IntegrationConnection @relation(fields: [connectionId], references: [id])
}

model PricingTable {
  id            String        @id @default(cuid())
  accountId     String
  provider      String
  serviceCode   String
  scope         String
  currency      String        @default("SAR")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  account       Account       @relation(fields: [accountId], references: [id])
  rules         PricingRule[]
}

model PricingRule {
  id                   String       @id @default(cuid())
  pricingTableId       String
  originZone           String
  destinationZone      String
  weightFrom           Decimal      @db.Decimal(10, 2)
  weightTo             Decimal      @db.Decimal(10, 2)
  volumetricDivisor    Int          @default(5000)
  baseAmount           Decimal      @db.Decimal(10, 2)
  codAmount            Decimal      @default(0) @db.Decimal(10, 2)
  remoteAreaAmount     Decimal      @default(0) @db.Decimal(10, 2)
  fuelSurchargePercent Decimal      @default(0) @db.Decimal(5, 2)
  pricingTable         PricingTable @relation(fields: [pricingTableId], references: [id])
}

model QuoteRequest {
  id              String        @id @default(cuid())
  accountId       String?
  originCity      String
  destinationCity String
  scope           String
  weight          Decimal       @db.Decimal(10, 2)
  volumetricWeight Decimal      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  account         Account?      @relation(fields: [accountId], references: [id])
  options         QuoteOption[]
}

model QuoteOption {
  id             String       @id @default(cuid())
  quoteRequestId String
  carrier        String
  service        String
  etaText        String
  price          Decimal      @db.Decimal(10, 2)
  breakdown      Json?
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  accountId  String
  actorUserId String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  account    Account  @relation(fields: [accountId], references: [id])

  @@index([accountId, entityType, entityId, createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  accountId String
  scope     String
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  account   Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, scope, key])
}
